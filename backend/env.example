# StudyBuddy Q backend — example environment
# Copy to backend/.env and fill in real values for local dev.
# NEVER commit a real .env file.

APP_ENV=development
LOG_LEVEL=INFO

# Redis — used for BYOK envelope storage and (later) Celery broker.
REDIS_URL=redis://localhost:6379/0

# BYOK master key — 64 hex characters (32 bytes).
# Generate with: python -c "import os; print(os.urandom(32).hex())"
# This is a server-side master from which per-job keys are derived (HKDF).
# It does NOT decrypt anything by itself — see ADR-001.
BYOK_MASTER_KEY=replace_me_with_64_hex_chars_replace_me_with_64_hex_chars_replace_me

# System-owner (super-admin) secret — 64 hex characters (32 bytes). See ADR-018.
# Authenticates owner-only actions (publishing a book into the default library,
# vault ops). Required at startup — the backend fails fast if unset.
# Generate with: openssl rand -hex 32
SYSTEM_OWNER_SECRET=replace_me_with_64_hex_chars_replace_me_with_64_hex_chars_replace
# Stable, non-secret owner identifier (publisher of record + audit actor).
# SYSTEM_OWNER_ID=mentible-system-owner

# Default Anthropic model used when the request body omits it.
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
