# StudyBuddy Q — ROOT environment for the Docker dev stack (./dev_start.sh up).
#
# Copy to `.env` (gitignored) in the repo root. docker-compose.yml interpolates
# these into the `api` service. (This is separate from backend/env.example, which
# is for running the backend WITHOUT Docker.)
#
# Anonymous demo: leave OIDC_ISSUER + DATABASE_URL unset — the backend starts with
# auth + accounts off. Set them to turn on User Management (ADR-014).

# ── Local-only secrets (compose falls back to dev defaults if unset) ───────────
# Generate real ones with: openssl rand -hex 32   (64 hex chars each)
# BYOK_MASTER_KEY=<64 hex>          # ADR-001
# SYSTEM_OWNER_SECRET=<64 hex>      # ADR-018 (must match the library-publish/CI value)

# ── User identity — Supabase (ADR-014 D1, O1) ─────────────────────────────────
OIDC_ISSUER=https://<project-ref>.supabase.co/auth/v1
# OIDC_AUDIENCE=authenticated      # default; only set if your tokens differ
# Requires asymmetric JWT signing keys on the Supabase project (the backend verifies
# via JWKS and rejects the legacy HS256 shared secret). Confirm keys exist:
#   curl https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json   # → non-empty "keys"

# ── Account store — Supabase Postgres via asyncpg (ADR-014 D2/D8) ─────────────
# ⚠️ Use the SESSION POOLER (port 5432). The direct host db.<ref>.supabase.co is
#    IPv6-only → fails inside Docker; the transaction pooler (6543) breaks asyncpg.
#    Copy the exact host from Supabase → Connect → Session pooler (the aws-N-<region>
#    prefix is project-specific). User is postgres.<ref>. URL-encode special chars in
#    the password (@ → %40) or use an alphanumeric one.
DATABASE_URL=postgresql://postgres.<project-ref>:<DB-PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres
