  },
  "bin": {
    "compile-epub": "dist/cli.js"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "katex": "0.16.9",
    "marked": "9.1.6",
    "marked-katex-extension": "4.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/katex": "^0.16.7",
    "@types/node": "^20.11.30",
    "fast-xml-parser": "^4.3.6",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5"
  }
}
