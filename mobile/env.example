# StudyBuddy Q — mobile environment
# Copy to .env.local and fill in the correct value for your setup.
# .env.local is gitignored and never committed.

# Backend URL the mobile app sends requests to.
#
# Android emulator on the same machine as the API:
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8001
#
# Physical Android device on the same LAN (replace with your machine's LAN IP):
# EXPO_PUBLIC_API_BASE_URL=http://192.168.x.x:8001
